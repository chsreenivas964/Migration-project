{
	"name": "DS_Sqlserver_Parquet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ADLS_SQL_PARQUET",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Table_Name": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(dataset().Table_Name,'_',formatDateTime(utcNow(),'yyyyMMddHHmmss'),'.parquet')\n",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat(dataset().Table_Name,'/',formatDateTime(utcNow(),'yyyy/MM/dd'))\n",
					"type": "Expression"
				},
				"fileSystem": "retail"
			},
			"compressionCodec": "snappy"
		},
		"schema": [
			{
				"name": "CustomerKey",
				"type": "INT32"
			},
			{
				"name": "CustomerID",
				"type": "INT32"
			},
			{
				"name": "FirstName",
				"type": "UTF8"
			},
			{
				"name": "LastName",
				"type": "UTF8"
			},
			{
				"name": "Email",
				"type": "UTF8"
			},
			{
				"name": "City",
				"type": "UTF8"
			},
			{
				"name": "Country",
				"type": "UTF8"
			},
			{
				"name": "StartDate",
				"type": "DATE"
			},
			{
				"name": "EndDate",
				"type": "DATE"
			},
			{
				"name": "IsCurrent",
				"type": "BOOLEAN"
			}
		]
	}
}